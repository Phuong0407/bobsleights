FoamFile
{
  version            2.0;
  format             ascii;
  class              volScalarField;
  object             omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions           [0 0 -1 0 0 0 0];
internalField        uniform 9000;

boundaryField
{
  inlet
  {
    type             fixedValue;
    value            $internalField;
  }

  outlet
  {
    type             zeroGradient;
  }

  bottom
  {
    type             omegaWallFunction;
    value            uniform 500000;
  }

  "(top|front|back)"
  {
    type             slip;
  }

  monobob
  {
    type             omegaWallFunction;
    value            uniform 500000;
  }
}



