FoamFile
{
  version            2.0;
  format             ascii;
  class              volScalarField;
  object             k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions           [0 2 -2 0 0 0 0];

internalField        uniform 3.375;

boundaryField
{
  inlet
  {
    type             fixedValue;
    value            $internalField;
  }

  outlet
  {
    type             zeroGradient;
  }

  bottom
  {
    type             kqRWallFunction;
    value            $intenralField;
  }

  "(top|front|back)"
  {
    type             slip;
  }

  monobob
  {
    type             kqRWallFunction;
    value            $intenralField;
  }
}


