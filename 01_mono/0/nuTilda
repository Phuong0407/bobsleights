FoamFile
{
  version          2.0;
  format           ascii;
  class            volScalarField;
  object           nuTilda;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions          [0 2 -1 0 0 0 0];

internalField       uniform 4.5e-5;

boundaryField
{
  inlet
  {
    type            fixedValue;
    value           uniform 4.5e-5;
  }
  outlet
  {
    type            zeroGradient;
  }
  top
  {
    type            freestream;
    freestreamValue uniform 4.5e-5;
  }
  bottom
  {
    type            fixedValue;
    value           uniform 0;
  }
  "(front|back)"
  {
    type            freestream;
    freestreamValue uniform 4.5e-5;
  }

  monobobGroup
  {
    type            fixedValue;
    value           uniform 0;
  }
}


