FoamFile
{
  version          2.0;
  format           ascii;
  class            volVectorField;
  object           U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions          [0 1 -1 0 0 0 0];

internalField       uniform (13.889 0 0);

boundaryField
{
  inlet
  {
    type            fixedValue;
    value           uniform (13.889 0 0);
  }
  outlet
  {
    type            freestreamVelocity;
    freestreamValue uniform (13.889 0 0);
    value           uniform (13.889 0 0);
  }
  top
  {
    type            freestreamVelocity;
    freestreamValue uniform (13.889 0 0);
    value           uniform (13.889 0 0);
  }
  bottom
  {
    type            movingWallVelocity;
    value           uniform (13.889 0 0);
  }
  "(front|back)"
  {
    type            freestreamVelocity;
    freestreamValue uniform (13.889 0 0);
    value           uniform (13.889 0 0);
  }

  monobobGroup
  {
    type            noSlip;
  }
}
