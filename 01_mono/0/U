FoamFile
{
  version            2.0;
  format             ascii;
  class              volVectorField;
  object             U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions           [0 1 -1 0 0 0 0];

internalField        uniform (13.889 0 0);

boundaryField
{
  inlet
  {
    type             fixedValue;
    value            $internalField;
  }

  outlet
  {
    type             inletOutlet;
    inletValue       $internalField;
    value            $internalField;
  }

  bottom
  {
    type             noSlip;
  }

  "(top|front|back)"
  {
    type             slip;
  }

  monobob
  {
    type             noSlip;
  }
}
