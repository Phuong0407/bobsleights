FoamFile
{
  version            2.0;
  format             ascii;
  class              volScalarField;
  object             nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions           [0 2 -1 0 0 0 0];

internalField        uniform 0;

boundaryField
{
  inlet
  {
    type             calculated;
    value            $internalField;
  }

  outlet
  {
    type             calculated;
    value            $internalField;
  }

  bottom
  {
    type             nutUSpaldingWallFunction;
    value            $internalField;
  }

  "(top|front|back)"
  {
    type             slip;
  }

  monobob
  {
    type             nutUSpaldingWallFunction;
    value            $internalField;
  }
}


