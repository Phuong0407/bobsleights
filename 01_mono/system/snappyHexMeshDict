FoamFile
{
  version          2.0;
  format           ascii;
  class            dictionary;
  object           snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

castellatedMesh    true;
snap               true;
addLayers          true;

geometry
{
  monobob.stl
  {
    type triSurfaceMesh;
    name monobob;
  }

  boxbot
  {
    type searchableBox;
    min  (-1.5 -0.5 -0.05);
    max  ( 1.5  0.5  0.02);
  }

  gearregion
  {
    type searchableBox;
    min  (-1.5 -0.15 -0.05);
    max  ( 1.5  0.15  0.12);
  }
}

castellatedMeshControls
{
  maxLocalCells       1200000;
  maxGlobalCells      10000000;
  minRefinementCells  10;
  maxLoadUnbalance    0.10;
  nCellsBetweenLevels 5;

  features
  (
    {
      file "monobob.eMesh";
      level 4;
    }
  );

  refinementSurfaces
  {
    monobob
    {
      level (4 4);
      patchInfo
      {
        type wall;
        inGroups (monobobGroup);
      }
    }
  }

  resolveFeatureAngle 30;

  refinementRegions
  {
    boxbot     { mode inside; levels ((1E15 2)); }
    gearregion { mode inside; levels ((1e15 3)); }
  }

  locationInMesh (5.00001 1.00001 1.00001);

  allowFreeStandingZoneFaces true;
}

snapControls
{
  nSmoothPatch           5;
  tolerance              2.0;
  nSolveIter             30;
  nRelaxIter             10;
  nFeatureSnapIter       10;
  implicitFeatureSnap    true;
  explicitFeatureSnap    false;
  multiRegionFeatureSnap true;
}

addLayersControls
{
  relativeSizes true;

  layers
  {
    "monobob.*"
    {
      nSurfaceLayers        4;
    }
  }

  expansionRatio            1.2;
  firstLayerThickness       0.0015;
  minThickness              0.0005;
  nGrow                     2;
  featureAngle              45;
  slipFeatureAngle          30;
  nRelaxIter                8;
  nSmoothSurfaceNormals     5;
  nSmoothNormals            3;
  nSmoothThickness          10;
  maxFaceThicknessRatio     0.3;
  maxThicknessToMedialRatio 0.3;
  minMedialAxisAngle        90;
  nBufferCellsNoExtrude     0;
  nLayerIter                50;
}

meshQualityControls
{
  #include "meshQualityDict"
  nSmoothScale 4;
  errorReduction 0.75;
}

writeFlags
(
  scalarLevels
  layerSets
  layerFields
);

mergeTolerance 1e-6;


// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
