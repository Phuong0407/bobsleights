FoamFile
{
  version          2.0;
  format           ascii;
  class            dictionary;
  object           snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

castellatedMesh    true;
snap               true;
addLayers          true;

geometry
{
  monobob.stl
  {
    type triSurfaceMesh;
    name monobob;
  }

  box1
  {
    type searchableBox;
    min  (0.4  0.15 -0.2);
    max  (1.35 0.45  0.3);
  }
  box2
  {
    type searchableBox;
    min  (0.4  -0.45 -0.2);
    max  (1.35 -0.15  0.3);
  }
  box3
  {
    type searchableBox;
    min  (1.2  0.15 0.5);
    max  (1.45 0.35 0.8);
  }
  box4
  {
    type searchableBox;
    min  (1.2  -0.35 0.5);
    max  (1.45 -0.15 0.8);
  }
  box5
  {
    type searchableBox;
    min  (-1.5 -0.45 -0.2);
    max  (-0.4  0.45 0.35);
  }
  boxbot
  {
    type searchableBox;
    min  (-5 -2.5 -0.05);
    max  (20  2.5   0.1);
  }

  badregion
  {
    type searchableBox;
    min  (0.2 -0.3 0.2);
    max  (0.4  0.2 0.5);
  }
}

castellatedMeshControls
{
  maxLocalCells       800000;
  maxGlobalCells      5000000;
  minRefinementCells  10;
  maxLoadUnbalance    0.10;
  nCellsBetweenLevels 7;

  features
  (
    {
      file "monobob.eMesh";
      level 4;
    }
  );

  refinementSurfaces
  {
    monobob
    {
      level (4 5);
      patchInfo
      {
        type wall;
        inGroups (monobobGroup);
      }
    }
  }

  resolveFeatureAngle 20;

  refinementRegions
  {
    box1   { mode inside; levels ((1E15 4)); }
    box2   { mode inside; levels ((1E15 4)); }
    box3   { mode inside; levels ((1E15 3)); }
    box4   { mode inside; levels ((1E15 3)); }
    box5   { mode inside; levels ((1E15 4)); }
    boxbot { mode inside; levels ((1E15 3)); }

    badregion { mode inside; levels ((1e15 5)); }
  }

  locationInMesh (5.00001 1.00001 1.00001);

  allowFreeStandingZoneFaces true;
}

snapControls
{
  nSmoothPatch           8;
  tolerance              1.0;
  nSolveIter             50;
  nRelaxIter             8;
  nFeatureSnapIter       10;
  implicitFeatureSnap    false;
  explicitFeatureSnap    true;
  multiRegionFeatureSnap false;
}

addLayersControls
{
  relativeSizes true;

  layers
  {
    "monobob.*"
    {
      nSurfaceLayers        6;
    }
  }

  expansionRatio            1.2;
  firstLayerThickness       0.0015;
  minThickness              0.0005;
  nGrow                     2;
  featureAngle              45;
  slipFeatureAngle          30;
  nRelaxIter                8;
  nSmoothSurfaceNormals     5;
  nSmoothNormals            3;
  nSmoothThickness          10;
  maxFaceThicknessRatio     0.3;
  maxThicknessToMedialRatio 0.3;
  minMedialAxisAngle        90;
  nBufferCellsNoExtrude     0;
  nLayerIter                50;
}

meshQualityControls
{
  #include "meshQualityDict"
  nSmoothScale 4;
  errorReduction 0.75;
}

writeFlags
(
  scalarLevels
  layerSets
  layerFields
);

mergeTolerance 1e-6;


