FoamFile
{
  version            2.0;
  format             ascii;
  class              dictionary;
  object             snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

castellatedMesh      true;
snap                 true;
addLayers            true;

geometry
{
  monobob.stl
  {
    type triSurfaceMesh;
    name monobob;
  }

  wake
  {
    type searchableBox;
    min  (-1.5 -1.2 0.0);
    max  (10.0  1.2 2.0);
  }

  separation
  {
    type searchableBox;
    min  (-2.0 -1.8 0.0);
    max  ( 8.0  1.8 2.5);
  }

  body
  {
    type searchableBox;
    min  (-1.5 -0.9 0.0);
    max  ( 1.5  0.9 1.5);
  }
}

castellatedMeshControls
{
  maxLocalCells               500000;
  maxGlobalCells              10000000;
  minRefinementCells          0;
  nCellsBetweenLevels         3;
  resolveFeatureAngle         30.0;
  allowFreeStandingZoneFaces  true;
  planarAngle                 30.0;
  maxLoadUnbalance            0.10;
  locationInMesh              (5.00001 1.00001 1.00001);

  features
  (
    {
      file "monobob.eMesh";
      level 6;
    }
  );

  refinementSurfaces
  {
    monobob
    {
      level (6 6);
      patchInfo { type wall; }
    }
  }

  resolveFeatureAngle 30;

  refinementRegions
  {
    wake       { mode inside; levels ((1E15 3)); }
    separation { mode inside; levels ((1e15 2)); }
    body 
    {
      mode distance;
      levels
      (
        (0.03 5)
        (0.10 4)
        (0.30 3)
      );
    }
  }
}

snapControls
{
  nSmoothPatch              5;
  tolerance                 2.0;
  nSolveIter                30;
  nRelaxIter                10;
  nFeatureSnapIter          10;
  implicitFeatureSnap       false;
  explicitFeatureSnap       true;
  multiRegionFeatureSnap    false;
}

addLayersControls
{
  relativeSizes             true;

  layers
  {

    "monobob.*"
    {
      nSurfaceLayers        5;
    }

    bottom
    {
      nSurfaceLayers        0;
    }
  }

  nGrow                     0;
  featureAngle              70.0;
  maxFaceThicknessRatio     0.5;
  nSmoothSurfaceNormals     1;
  nSmoothNormals            3;
  nSmoothThickness          10;
  slipFeatureAngle          30.0;
  nRelaxIter                5;
  maxThicknessToMedialRatio 0.3;
  minMedialAxisAngle        90;
  minMedianAxisAngle        90;
  nBufferCellsNoExtrude     0;
  nLayerIter                50;
  nRelaxedIter              20;
  expansionRatio            1.2;
  finalLayerThickness       0.15;
  minThickness              0.05;
}

meshQualityControls
{
  #include                  "meshQualityDict"
  nSmoothScale              6;
  errorReduction            0.85;

  relaxed { maxNonOrtho     75; }
}

writeFlags
(
  scalarLevels
  layerSets
  layerFields
);

mergeTolerance 1.0E-6;


// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
