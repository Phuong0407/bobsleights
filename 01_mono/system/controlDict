FoamFile
{
  version            2.0;
  format             ascii;
  class              dictionary;
  object             controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


application          simpleFoam;

startFrom            latestTime;

startTime            0;

stopAt               endTime;

endTime              10000;

deltaT               1;

writeControl         timeStep;

writeInterval        100;

purgeWrite           10;

writeFormat          ascii;

writePrecision       6;

writeCompression     off;

timeFormat           general;

timePrecision        6;

runTimeModifiable    true;

functions
{
  forces
  {
    type             forces;
    libs             ("libforces.so");

    patches          (monobob);

    rho              rhoInf;
    rhoInf           1.225;
    CofR             (0 0 0);

    log              yes;
    timeStart        50;
    writeControl     timeStep;
    writeInterval    10;
    log              yes;
  }

  yPlus
  {
    type             yPlus;
    libs             ("libfieldFunctionObjects.so");
    enabled          true;
    timeStart        50;
    writeControl     timeStep;
    writeInterval    100;
    log              yes;
  }
}


