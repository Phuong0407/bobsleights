FoamFile
{
  version            2.0;
  format             ascii;
  class              dictionary;
  object             fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
  p
  {
    solver           GAMG;
    tolerance        1e-07;
    relTol           0.01;
    smoother         GaussSeidel;
  }

  pFinal
  {
    $p;
    tolerance        1e-08;
    relTol           0;
  }

  "(U|nuTilda)"
  {
    solver           smoothSolver;
    tolerance        1e-08;
    relTol           0.1;
    smoother         GaussSeidel;
  }

  "(U|nuTilda)Final"
  {
    $U;
    relTol           0;
  }
}

SIMPLE
{
  nNonOrthogonalCorrectors  0;
  consisten                 yes;

  residualControl
  {
    p                1e-5;
    U                1e-6;
    nuTilda          1e-6;
}

relaxationFactors
{
  fields
  {
    p                0.3;
  }

  equations
  {
    U                0.7;
    nuTilda          0.5;
  }
}

cache
{
  grad(U);
}

