FoamFile
{
  version             2.0;
  format              ascii;
  class               dictionary;
  object              fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
  p
  {
    solver                   PCG;
    preconditioner
    {
      preconditioner         GAMG;
      tolerance              1e-06;
      relTol                 0;
      nVcycles               2;
      smoother               GaussSeidel;
      nPreSweeps             0;
      nPostSweeps            2;
      nFinestSweeps          2;
      cacheAgglomeration     false;
      nCellsInCoarsestLevel  10;
      agglomerator           faceAreaPair;
      mergeLevels            1;
    }
    tolerance                1e-07;
    relTol                   0.01;
    minIter                  1;
  }

  pFinal
  {
    $p;
    tolerance                1e-08;
    relTol                   0;
  }

  U
  {
    solver                   PBiCGStab;
    preconditioner           DILU;
    tolerance                1e-06;
    relTol                   0.01;
    minIter                  1;
  }

  nuTilda
  {
    solver                   PBiCGStab;
    preconditioner           DILU;
    tolerance                1e-6;
    relTol                   0.01;
    minIter                  1;
  }

  Phi
  {
    solver                   GAMG;
    agglomerator             faceAreaPair;
    mergeLevels              1;
    cacheAgglomeration       true;
    nCellsInCoarsestLevel    200;
    tolerance                1e-6;
    relTol                   0.01;
    smoother                 GaussSeidel;
    nPreSweeps               0;
    nPostSweeps              2;
    nFinestSweeps            2;
    minIter                  1;
  }
}

potentialFlow
{
  nNonOrthogonalCorrectors   10;
}

SIMPLE
{
  momentumPredictor          yes;
  nOuterCorrectors           2;
  nCorrectors                2;
  nNonOrthogonalCorrectors   1;
  consistent                 yes;

  pRefCell                   0;
  pRefValue                  0;

  residualControl
  {
    p                        1e-3;
    U                        1e-3;
    nuTilda                  2e-3;
  }
}

relaxationFactors
{
  fields
  {
    ".*"                     0.7;
  }

  equations
  {
    ".*"                     0.7;
  }
}

cache
{
  grad(U);
  grad(nuTilda);
}


