);

edges
(
);

boundary
(

  inlet
  {
    type patch;
    faces
    (
      (0 4 7 3)
    );
  }

  outlet
  {
    type patch;
    faces
    (
      (1 2 6 5)
    );
  }

  top
  {
    type symmetryPlane;
    faces
    (
      (4 5 6 7)
    );
  }

  bottom
  {
    type wall;
    faces
    (
      (0 3 2 1)
    );
  }

  front
  {
    type symmetryPlane;
    faces
    (
      (0 1 5 4)
    );
  }

  back
  {
    type symmetryPlane;
    faces
    (
      (2 3 7 6)
    );
  }

);

mergePatchPairs
(
);


