FoamFile
{
  version            2.0;
  format             ascii;
  class              dictionary;
  object             snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

castellatedMesh      true;
snap                 true;
addLayers            true;

geometry
{
  monobob.stl
  {
    type triSurfaceMesh;
    name monobob;
  }

  body
  {
    type searchableBox;
    min  (-1.8 -0.7 0.0);
    max  ( 1.8  0.7 1.5);
  }

  separation
  {
    type searchableBox;
    min  (-2.5 -1.2 0.0);
    max  ( 3.5  1.2 1.8);
  }

  wake
  {
    type searchableBox;
    min  (1.0  -1.5 0.0);
    max  (10.0  1.5 2.0);
  }
}

castellatedMeshControls
{
  locationInMesh              (5.00001 1.00001 1.00001);

  maxLocalCells               600000;
  maxGlobalCells              12000000;
  minRefinementCells          0;
  maxLoadUnbalance            0.1;
  nCellsBetweenLevels         3;

  resolveFeatureAngle         30;
  allowFreeStandingZoneFaces  true;
  planarAngle                 30;

  features
  (
    {
      file "monobob.eMesh";
      level 6;
    }
  );

  refinementSurfaces
  {
    monobob
    {
      level (5 6);
      patchInfo
      {
        type wall;
      }
    }
  }

  refinementRegions
  {
    wake       { mode inside; levels ((1E15 2)); }
    separation { mode inside; levels ((1e15 4)); }

    body 
    {
      mode distance;
      levels
      (
        (0.03 6)
        (0.10 5)
        (0.30 4)
      );
    }
  }
}

snapControls
{
  nSmoothPatch              5;
  tolerance                 2;
  nSolveIter                30;
  nRelaxIter                10;
  nFeatureSnapIter          10;
  implicitFeatureSnap       false;
  explicitFeatureSnap       true;
  multiRegionFeatureSnap    false;
}

addLayersControls
{
  layers
  {
    "monobob.*"
    {
      nSurfaceLayers        8;
    }

    bottom
    {
      nSurfaceLayers        5;
    }
  }

  relativeSizes             false;
  expansionRatio            1.2;
  firstLayerThickness       0.001;
  minThickness              0.0001;
  nGrow                     0;

  featureAngle              75;
  maxFaceThicknessRatio     0.5;

  nSmoothSurfaceNormals     2;
  nSmoothNormals            5;
  nSmoothThickness          10;
  slipFeatureAngle          50;

  nRelaxIter                5;

  maxThicknessToMedialRatio 0.3;
  minMedialAxisAngle        60;
  minMedianAxisAngle        60;
  nBufferCellsNoExtrude     0;

  nLayerIter                50;
  nRelaxedIter              20;
}

meshQualityControls
{
  #include                  "meshQualityDict"
  nSmoothScale              6;
  errorReduction            0.85;

  relaxed { maxNonOrtho     75; }
}

writeFlags
(
  scalarLevels
  layerSets
  layerFields
);

mergeTolerance 1.0E-6;


// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
