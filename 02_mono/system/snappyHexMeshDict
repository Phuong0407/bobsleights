FoamFile
{
  version            2.0;
  format             ascii;
  class              dictionary;
  object             snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

castellatedMesh      true;
snap                 true;
addLayers            true;

geometry
{
  monobob.stl
  {
    type triSurfaceMesh;
    name monobob;
  }

  body
  {
    type searchableBox;
    min  (-1.8 -0.7 0.0);
    max  ( 1.8  0.7 1.5);
  }

  separation
  {
    type searchableBox;
    min  (-2.5 -1.2 0.0);
    max  ( 3.5  1.2 1.8);
  }

  wake
  {
    type searchableBox;
    min  (-7.5 -1.5 0.0);
    max  (20.0  1.5 2.0);
  }

  rear1
  {
    type searchableBox;
    min (-1.1 -0.4 0.45);
    max (-0.4 -0.2 0.70);
  }

  rear2
  {
    type searchableBox;
    min (0.48 -0.4 0.45);
    max (1.36 -0.2 0.70);
  }

  rear3
  {
    type searchableBox;
    min (-1.1 0.2 0.45);
    max (-0.4 0.4 0.70);
  }

  rear4
  {
    type searchableBox;
    min (0.48 0.2 0.45);
    max (1.36 0.4 0.70);
  }

  athlete
  {
    type         searchableCone;
    point1       (0.05 0.0 0.9);
    point2       (0.85 0.0 0.9);
    radius1      0.22;
    innerRadius1 0.0;
    radius2      0.27;
    innerRadius2 0.0;
  }

  helmet
  {
    type   searchableSphere;
    centre (0.725 0.0 1.2);
    radius 0.2;
  }
}

castellatedMeshControls
{
  locationInMesh              (5.00001 1.00001 1.00001);

  maxLocalCells               500000;
  maxGlobalCells              10000000;
  minRefinementCells          0;
  maxLoadUnbalance            0.1;
  nCellsBetweenLevels         5;

  resolveFeatureAngle         30;
  allowFreeStandingZoneFaces  true;
  planarAngle                 30;

  features
  (
    {
      file "monobob.eMesh";
      level 2;
    }
  );

  refinementSurfaces
  {
    monobob
    {
      level (4 4);
      patchInfo
      {
        type wall;
      }
    }
  }

  refinementRegions
  {
    wake       { mode inside; levels ((1E15 2)); }
    separation { mode inside; levels ((1e15 3)); }
    body       { mode inside; levels ((1e15 4)); }

    rear1      { mode inside; levels ((1e15 5)); }
    rear2      { mode inside; levels ((1e15 5)); }
    rear3      { mode inside; levels ((1e15 5)); }
    rear4      { mode inside; levels ((1e15 5)); }

    athlete    { mode inside; levels ((1e15 5)); }
    helmet     { mode inside; levels ((1e15 5)); }
  }
}

snapControls
{
  nSmoothPatch              10;
  tolerance                 1.0;
  nSolveIter                30;
  nRelaxIter                10;
  nFeatureSnapIter          10;
  implicitFeatureSnap       false;
  explicitFeatureSnap       true;
  multiRegionFeatureSnap    false;
}

addLayersControls
{
  layers
  {
    "monobob.*"
    {
      nSurfaceLayers        2;
    }

    bottom
    {
      nSurfaceLayers        0;
    }
  }

  relativeSizes             false;
  expansionRatio            1.15;
  firstLayerThickness       0.003;
  minThickness              0.001;
  nGrow                     0;

  featureAngle              75;
  maxFaceThicknessRatio     0.5;

  nSmoothSurfaceNormals     1;
  nSmoothNormals            3;
  nSmoothThickness          10;
  slipFeatureAngle          30;

  nRelaxIter                5;

  maxThicknessToMedialRatio 0.3;
  minMedialAxisAngle        60;
  minMedianAxisAngle        60;
  nBufferCellsNoExtrude     0;

  nLayerIter                50;
  nRelaxedIter              20;
}

meshQualityControls
{
  #include                  "meshQualityDict"
  nSmoothScale              6;
  errorReduction            0.75;

  relaxed
  {
    maxNonOrtho             75;
  }
}

writeFlags
(
  scalarLevels
  layerSets
  layerFields
);

mergeTolerance 1.0E-6;


